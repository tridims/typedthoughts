---
import type { CollectionEntry } from "astro:content";
import Footer from "@/components/footer/Footer.astro";
import BaseHead from "@/components/header/BaseHead.astro";
import Header from "@/components/header/Header.astro";
import FormattedDate from "@/components/utils/FormattedDate.astro";

type Props = CollectionEntry<"til">["data"] & { ogImage?: string };

const { title, description, pubDate, updatedDate, tags, ogImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead description={description ?? title} ogImage={ogImage} title={title} />
  </head>

  <body class="bg-background text-foreground">
    <Header />
    <main class="pt-20">
      <article class="max-w-2xl mx-auto px-6 py-12">
        <div class="mb-6">
          <a
            class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-200"
            href="/til/"
          >
            ← All TIL
          </a>
        </div>

        <header class="mb-8">
          <div
            class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-wider text-popover mb-3"
          >
            <span
              class="flex h-5 w-5 items-center justify-center rounded border border-popover/40"
            >
              💡
            </span>
            Today I Learned
          </div>

          <h1
            class="text-3xl md:text-4xl font-extrabold tracking-tight text-balance mb-3"
          >
            {title}
          </h1>

          <div class="text-sm text-muted-foreground">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                <span class="mx-2">&bull;</span>
                <span>
                  {"Updated on "}<FormattedDate date={updatedDate} />
                </span>
              </>
            )}
          </div>

          {tags && tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="inline-flex items-center rounded-md border border-border bg-secondary/30 px-2.5 py-1 text-xs font-medium leading-none text-muted-foreground">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <hr class="border-border my-8">

        <div
          class="prose prose-lg dark:prose-invert max-w-none
                        prose-headings:text-foreground
                        prose-p:text-foreground
                        prose-a:text-orange-500 prose-a:no-underline hover:prose-a:underline
                        prose-strong:text-foreground
                        prose-blockquote:border-orange-500 prose-blockquote:text-muted-foreground
                        prose-li:marker:text-orange-500
                        prose-code:rounded-md prose-code:px-1.5 prose-code:py-1 prose-code:font-mono prose-code:text-sm
                        "
        >
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
