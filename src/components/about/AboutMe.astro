---
import { Image } from "astro:assets";
import { Rss } from "@lucide/astro";
import { FaGithub, FaLinkedin, FaMedium } from "react-icons/fa";

import socialImage from "../../assets/cat.jpeg";

const socialLinks = [
  {
    name: "GitHub",
    href: "https://github.com/tridims",
    icon: FaGithub,
    handle: "@tridims",
  },
  {
    name: "LinkedIn",
    href: "https://linkedin.com/in/dimastrim",
    icon: FaLinkedin,
    handle: "@dimastrim",
  },
  {
    name: "Medium",
    href: "https://medium.com/@tridims",
    icon: FaMedium,
    handle: "@tridims",
  },
];

const linkedIn = socialLinks.find((link) => link.name === "LinkedIn");

const otherLinks = socialLinks.filter((link) => link.name !== "LinkedIn");
const generalHandle = "@tridims"; // Change this to your preferred general handle
---

<div class="flex flex-col md:flex-row items-center gap-4 mb-4 top-20">
  <Image
    alt="Personal Image"
    class="w-20 h-20 sm:w-26 sm:h-26 rounded-3xl object-cover shrink-0"
    src={socialImage}
  />
  <div class="text-center sm:text-left">
    <p class="text-sm sm:text-lg text-primary-background">
      Software Engineer, Toolmaker, Homelab Enthusiast
    </p>
  </div>
</div>

<a
  class="inline-block w-full text-center border border-neutral-700 rounded-lg px-4 py-2 text-sm text-foreground hover:bg-popover transition-colors mb-8"
  data-astro-prefetch
  href="/about"
>
  About Me &rarr;
</a>

<h3 class="font-semibold text-foreground mb-4 md:block hidden">Follow</h3>
<div
  class="flex flex-col items-center border border-neutral-700 rounded-2xl p-4 sm:p-8 shadow-lg"
>
  <!-- Top Row: LinkedIn -->
  {linkedIn &&
            (() => {
                const Icon = linkedIn.icon;

                return (
                    <a
                        class="mb-6 flex items-center gap-3 text-foreground transition-colors hover:text-popover sm:mb-8 sm:gap-4"
                        href={linkedIn.href}
                        rel="noopener noreferrer"
                        target="_blank"
                    >
                        <Icon class="shrink-0 text-3xl sm:text-4xl" />
                        <span class="truncate font-medium font-sans text-base tracking-tight sm:text-xl">
                            {linkedIn.handle}
                        </span>
                    </a>
                );
            })}

  <!-- Middle Row: Other Social Icons -->
  <div class="flex flex-wrap items-center gap-3 sm:gap-5">
    {otherLinks.map(({ href, icon: Icon }) => (
                <a
                    class="shrink-0 text-foreground transition-colors hover:text-popover"
                    href={href}
                    rel="noopener noreferrer"
                    target="_blank"
                >
                    <Icon class="text-2xl sm:text-3xl" />
                </a>
            ))}

    <span class="text-foreground text-sm ml-0 font-medium truncate">
      {generalHandle}
    </span>
  </div>
</div>

<a
  class="inline-block w-full text-center border border-neutral-700 rounded-lg px-4 py-2 text-sm text-foreground hover:bg-popover transition-colors mt-8"
  data-astro-prefetch
  href="/tags"
>
  Browse Tags &rarr;
</a>

<a
  class="inline-block w-full text-center border border-neutral-700 rounded-lg px-4 py-2 text-sm text-foreground hover:bg-popover transition-colors mt-4"
  data-astro-prefetch
  href="/uses"
>
  Uses / Gear &rarr;
</a>

<a
  class="inline-block w-full text-center border border-neutral-700 rounded-lg px-4 py-2 text-sm text-foreground hover:bg-popover transition-colors mt-4"
  data-astro-prefetch
  href="/now"
>
  What I'm Doing Now &rarr;
</a>

<a
  class="inline-block w-full text-center border border-neutral-700 rounded-lg px-4 py-2 text-sm text-foreground hover:bg-popover transition-colors mt-4"
  data-astro-prefetch
  href="/til"
>
  Today I Learned &rarr;
</a>

<a
  class="inline-flex items-center justify-center gap-2 w-full text-center border border-neutral-700 rounded-lg px-4 py-2 text-sm text-foreground hover:bg-popover transition-colors mt-4"
  href="/rss.xml"
>
  <Rss class="h-4 w-4" />
  Subscribe via RSS
</a>
