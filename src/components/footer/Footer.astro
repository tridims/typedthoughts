---
import { Rss } from "@lucide/astro";

const today = new Date();
---

<footer
  class="text-zinc-500 p-4 flex flex-col items-center gap-3 text-center text-sm"
>
  <a
    class="group inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1 text-xs font-medium text-muted-foreground transition-colors hover:border-popover hover:text-popover"
    href="/rss.xml"
    title="Subscribe to the RSS feed"
  >
    <Rss class="h-3.5 w-3.5" />
    <span>RSS</span>
  </a>

  <div>
    &copy; {today.getFullYear()}
    <a class="hover:text-foreground transition-colors" data-astro-prefetch href="/">
      Dimas Tri Mustakim
    </a>
  </div>
</footer>
