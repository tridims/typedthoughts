---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"til">;
}

const { entry } = Astro.props;
const { title, pubDate, description, tags } = entry.data;

// Format the date like the rest of the site: YYYY-MM-DD
const formattedDate = new Date(pubDate).toISOString().split("T")[0];
---

<article class="py-4 border-b border-border/60 last:border-b-0">
  <a
    class="block group"
    data-astro-prefetch="viewport"
    href={`/til/${entry.id}/`}
  >
    <time
      class="font-mono text-sm text-muted"
      datetime={pubDate.toISOString()}
    >
      {formattedDate}
    </time>
    <h2
      class="text-lg font-bold text-foreground mt-1 group-hover:text-popover transition-colors duration-300 flex items-center gap-2"
    >
      {title}
      <span
        class="text-popover opacity-0 group-hover:opacity-100 transition-opacity duration-300 -translate-x-2 group-hover:translate-x-0"
        >↗</span
      >
    </h2>
    {description && (
      <p class="text-muted-foreground text-sm mt-2 leading-relaxed">
        {description}
      </p>
    )}
  </a>
  {tags && tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="inline-flex items-center rounded-md border border-border bg-secondary/30 px-2.5 py-1 text-xs font-medium leading-none text-muted-foreground">
          #{tag}
        </span>
      ))}
    </div>
  )}
</article>
